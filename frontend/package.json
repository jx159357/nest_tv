{
  "name": "tv-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --pool threads --poolOptions.threads.singleThread",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage --pool threads --poolOptions.threads.singleThread",
    "test:ci": "vitest run --coverage --pool threads --poolOptions.threads.singleThread",
    "test:journeys": "vitest run --pool threads --poolOptions.threads.singleThread test/views/LoginView.spec.ts test/views/RegisterView.spec.ts test/views/UserJourney.spec.ts test/views/AuthProfileJourney.spec.ts",
    "test:journeys:admin": "vitest run --pool threads --poolOptions.threads.singleThread test/views/AdminJourney.spec.ts",
    "test:tools": "vitest run --pool threads --poolOptions.threads.singleThread test/stores/downloads.spec.ts test/utils/clipboard.spec.ts test/views/DownloadsView.spec.ts test/views/TorrentView.spec.ts test/views/WatchView.spec.ts",
    "test:regressions": "npm run test:journeys && npm run test:journeys:admin && npm run test:tools",
    "lint": "node --max-old-space-size=4096 ./node_modules/eslint/bin/eslint.js . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "lint:check": "node --max-old-space-size=4096 ./node_modules/eslint/bin/eslint.js . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "type-check": "node --max-old-space-size=8192 ./node_modules/vue-tsc/bin/vue-tsc.js --noEmit"
  },
  "dependencies": {
    "artplayer": "^5.4.0",
    "artplayer-plugin-hls-control": "^1.1.0",
    "axios": "^1.6.0",
    "dompurify": "^3.4.8",
    "hls.js": "^1.6.16",
    "pinia": "^2.1.0",
    "socket.io-client": "^4.8.1",
    "vue": "^3.4.0",
    "vue-i18n": "^11.1.11",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@intlify/devtools-types": "^11.1.12",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.10.0",
    "@unocss/preset-attributify": "^0.58.0",
    "@unocss/preset-icons": "^0.58.0",
    "@unocss/preset-uno": "^0.58.0",
    "@vitejs/plugin-vue": "^4.5.0",
    "@vitest/coverage-istanbul": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.5.0",
    "csstype": "^3.1.3",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "eslint-plugin-vue": "^9.19.0",
    "husky": "^8.0.0",
    "jsdom": "^23.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0",
    "unocss": "^0.58.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vue-tsc": "^3.0.6"
  }
}
