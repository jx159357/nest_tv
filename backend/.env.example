NODE_ENV=development
PORT=3334

# 数据库配置（需要提前创建数据库）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_mysql_password
DB_DATABASE=nest_tv
DB_SYNCHRONIZE=true
DB_LOGGING=false
DB_RETRY_ATTEMPTS=5
DB_RETRY_DELAY=5000

# Redis 配置（可选，不配置时自动降级为内存缓存）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=nest-tv-dev-secret-change-in-production
JWT_EXPIRES_IN=7d
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800
JWT_AUDIENCE=nest-tv-client
JWT_ISSUER=nest-tv-server

# CORS 配置
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 日志配置
LOG_LEVEL=log
LOG_TO_FILE=false
LOG_FILE_PATH=./logs

# 初始化数据（首次启动时自动创建管理员账号和示例数据）
ALLOW_INIT_DEFAULT_DATA=true

# 代理池（默认关闭，需要代理时开启）
PROXY_POOL_ENABLED=false

# 定时爬虫（默认关闭）
ENABLE_SCHEDULED_CRAWL=false
SCHEDULE_CRAWL_INTERVAL=6h

# 安全配置
BCRYPT_ROUNDS=10
ENABLE_RATE_LIMIT=false
ENABLE_CSP=false
ENABLE_HELMET_SECURITY=false
